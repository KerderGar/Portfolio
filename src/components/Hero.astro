---
import { getTranslation, type Locale } from "../i18n";
import { withBase } from "../utils/path";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslation(locale);
---

<section class="relative min-h-[921px] flex items-center justify-center px-margin-mobile md:px-margin-desktop hero-glow overflow-hidden">
  <div class="max-w-[1280px] w-full grid grid-cols-1 md:grid-cols-12 gap-md items-center">
    <div class="md:col-span-7 z-10">
      <div class="inline-block px-sm py-1 bg-secondary-container/20 border border-secondary/30 rounded-full mb-md">
        <span class="font-label-sm text-label-sm text-secondary uppercase tracking-widest">{t.hero.badge}</span>
      </div>
      <h1 class="font-display text-display mb-sm leading-none">
        Keryms Deyanira <br />
        <span class="text-gradient">Garcia Reyes</span>
      </h1>
      <p class="font-headline-md text-headline-md text-on-surface-variant mb-lg max-w-2xl">
        {t.hero.subtitle}
      </p>
      <div class="flex flex-wrap gap-md">
        <button class="bg-primary text-on-primary font-label-md text-label-md px-lg py-sm rounded transition-transform hover:scale-105">
          {t.hero.btnProjects}
        </button>
        <button class="border border-primary text-primary font-label-md text-label-md px-lg py-sm rounded hover:bg-primary/10 transition-colors">
          {t.hero.btnBio}
        </button>
      </div>
    </div>
    <div class="md:col-span-5 relative flex justify-center items-center">
      <div class="relative w-80 h-96">
        <div class="absolute inset-0 border-2 border-secondary/40 -translate-x-4 translate-y-4"></div>
        <div class="absolute inset-0 bg-surface-container-high overflow-hidden border border-outline-variant/50">
          <img
            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
            alt="Professional portrait of Keryms Garcia Reyes"
            src={withBase('profilePortfolio.webp')}
          />
        </div>
        <div class="absolute -bottom-8 -right-8 w-32 h-32 bg-secondary/10 backdrop-blur-md border border-secondary/20 flex flex-col items-center justify-center">
          <span class="font-display text-headline-lg text-secondary">{t.hero.yearsXp}</span>
          <span class="font-label-sm text-label-sm text-on-surface-variant">{t.hero.yearsLabel}</span>
        </div>
      </div>
    </div>
  </div>
</section>
