---
import { getTranslation, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslation(locale);
---

<section class="py-xl px-margin-mobile md:px-margin-desktop" id="skills">
  <div class="max-w-[1280px] mx-auto">
    <div class="flex items-center gap-sm mb-lg">
      <span class="h-[1px] w-12 bg-primary"></span>
      <h2 class="font-label-md text-label-md tracking-widest text-primary uppercase">{t.skills.title}</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-md">
      <!-- Automation -->
      <div class="glass-card p-md rounded-lg">
        <div class="flex items-center gap-xs mb-sm">
          <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">robot_2</span>
          <h3 class="font-headline-md text-headline-md text-on-surface">{t.skills.automation.title}</h3>
        </div>
        <ul class="space-y-xs font-body-md text-on-surface-variant">
          {t.skills.automation.items.map((item) => (
            <li class="flex items-center gap-xs"><span class="w-1 h-1 bg-secondary rounded-full"></span> {item}</li>
          ))}
        </ul>
      </div>
      <!-- Performance -->
      <div class="glass-card p-md rounded-lg">
        <div class="flex items-center gap-xs mb-sm">
          <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">speed</span>
          <h3 class="font-headline-md text-headline-md text-on-surface">{t.skills.performance.title}</h3>
        </div>
        <ul class="space-y-xs font-body-md text-on-surface-variant">
          {t.skills.performance.items.map((item) => (
            <li class="flex items-center gap-xs"><span class="w-1 h-1 bg-secondary rounded-full"></span> {item}</li>
          ))}
        </ul>
      </div>
      <!-- DevOps -->
      <div class="glass-card p-md rounded-lg">
        <div class="flex items-center gap-xs mb-sm">
          <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">terminal</span>
          <h3 class="font-headline-md text-headline-md text-on-surface">{t.skills.devops.title}</h3>
        </div>
        <ul class="space-y-xs font-body-md text-on-surface-variant">
          {t.skills.devops.items.map((item) => (
            <li class="flex items-center gap-xs"><span class="w-1 h-1 bg-secondary rounded-full"></span> {item}</li>
          ))}
        </ul>
      </div>
      <!-- Methods -->
      <div class="glass-card p-md rounded-lg">
        <div class="flex items-center gap-xs mb-sm">
          <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">account_tree</span>
          <h3 class="font-headline-md text-headline-md text-on-surface">{t.skills.methods.title}</h3>
        </div>
        <ul class="space-y-xs font-body-md text-on-surface-variant">
          {t.skills.methods.items.map((item) => (
            <li class="flex items-center gap-xs"><span class="w-1 h-1 bg-secondary rounded-full"></span> {item}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
