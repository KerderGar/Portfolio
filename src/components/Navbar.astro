---
import { getTranslation, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslation(locale);
const otherLang = locale === "en" ? "es" : "en";
const otherUrl = locale === "en" ? "/es/" : "/en/";
const otherLabel = locale === "en" ? t.lang.es : t.lang.en;
---

<nav
  id="navbar"
  class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-xl border-b border-outline-variant/30 transition-all duration-300 ease-in-out py-4"
>
  <div class="flex justify-between items-center max-w-[1280px] mx-auto px-margin-desktop py-4">
    <div class="font-label-md text-label-md font-bold tracking-tighter text-secondary dark:text-secondary">
      {t.brand}
    </div>
    <div class="hidden md:flex gap-md">
      <a class="font-body-md text-body-md text-on-surface-variant dark:text-on-surface-variant hover:text-primary transition-colors" href="#about">{t.nav.about}</a>
      <a class="font-body-md text-body-md text-on-surface-variant dark:text-on-surface-variant hover:text-primary transition-colors" href="#skills">{t.nav.skills}</a>
      <a class="font-body-md text-body-md text-on-surface-variant dark:text-on-surface-variant hover:text-primary transition-colors" href="#experience">{t.nav.experience}</a>
      <a class="font-body-md text-body-md text-on-surface-variant dark:text-on-surface-variant hover:text-primary transition-colors" href="#projects">{t.nav.projects}</a>
    </div>
    <div class="flex items-center gap-sm">
      <a href={otherUrl} class="text-sm text-on-surface-variant hover:text-primary transition-colors border border-outline-variant/30 px-sm py-1 rounded">
        {otherLabel}
      </a>
      <a href="mailto:kerymsgarcia@gmail.com" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="Email">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg>
      </a>
      <a href="https://linkedin.com/in/Keryms-Garcia" target="_blank" rel="noopener" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
      </a>
    </div>
  </div>
</nav>

<script>
  window.addEventListener("scroll", () => {
    const nav = document.getElementById("navbar");
    if (!nav) return;
    if (window.scrollY > 50) {
      nav.classList.add("py-2");
      nav.classList.remove("py-4");
      nav.classList.add("bg-surface/95");
    } else {
      nav.classList.add("py-4");
      nav.classList.remove("py-2");
      nav.classList.remove("bg-surface/95");
    }
  });
</script>
