---
import { getTranslation, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslation(locale);
---

<section class="py-xl px-margin-mobile md:px-margin-desktop bg-surface-container-low/30" id="experience">
  <div class="max-w-[1280px] mx-auto">
    <div class="flex items-center gap-sm mb-lg">
      <span class="h-[1px] w-12 bg-secondary"></span>
      <h2 class="font-label-md text-label-md tracking-widest text-secondary uppercase">{t.experience.title}</h2>
    </div>
    <div class="space-y-lg">
      {t.experience.jobs.map((job, index) => (
        <div class={`relative pl-lg border-l border-outline-variant/50 ${index < t.experience.jobs.length - 1 ? 'pb-lg' : ''}`}>
          <div class={`absolute -left-[5px] top-0 w-2 h-2 rounded-full ${index === 0 ? 'bg-primary ring-4 ring-primary/20' : 'bg-outline'}`}></div>
          <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-sm">
            <div>
              <h3 class="font-headline-md text-headline-md text-on-surface">{job.title}</h3>
              <p class="font-label-md text-label-md text-primary">{job.company}</p>
            </div>
            <span class="font-label-sm text-label-sm text-on-surface-variant bg-surface-container-high px-sm py-1 rounded">{job.period}</span>
          </div>
          <p class="font-body-md text-body-md text-on-surface-variant max-w-3xl mb-sm">
            {job.summary}
          </p>
          <ul class="space-y-xs font-body-md text-on-surface-variant max-w-3xl">
            {job.highlights.map((item) => (
              <li class="flex items-start gap-xs">
                <span class="w-1.5 h-1.5 bg-secondary rounded-full mt-2 shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
