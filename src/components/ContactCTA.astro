---
import { getTranslation, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslation(locale);
---

<section class="py-xl px-margin-mobile md:px-margin-desktop bg-gradient-to-br from-surface-container-lowest to-surface">
  <div class="max-w-[800px] mx-auto text-center">
    <h2 class="font-headline-lg text-headline-lg mb-md">
      {t.cta.title} <br /><span class="text-gradient">{t.cta.highlight}</span>
    </h2>
    <p class="font-body-lg text-body-lg text-on-surface-variant mb-lg">
      {t.cta.description}
    </p>
    <div class="flex justify-center gap-md">
      <a
        class="bg-primary text-on-primary font-label-md text-label-md px-lg py-sm rounded-lg hover:shadow-lg hover:shadow-primary/20 transition-all"
        href="mailto:kerymsgarcia@gmail.com"
      >
        {t.cta.button}
      </a>
    </div>
  </div>
</section>
