---
import { getTranslation, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslation(locale);
---

<section class="py-xl px-margin-mobile md:px-margin-desktop bg-surface-container-lowest/50" id="about">
  <div class="max-w-[1280px] mx-auto">
    <div class="flex flex-col md:flex-row gap-lg items-center">
      <div class="md:w-1/3">
        <h2 class="font-headline-lg text-headline-lg mb-sm">
          {t.about.title} <br /><span class="text-gradient">{t.about.highlight}</span> <br />{t.about.title2}
        </h2>
      </div>
      <div class="md:w-2/3">
        <p class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed">
          {t.about.bio}
        </p>
        <div class="mt-lg grid grid-cols-2 md:grid-cols-4 gap-md">
          <div class="border-l-2 border-primary pl-md">
            <p class="font-label-md text-label-md text-primary">0%</p>
            <p class="font-label-sm text-label-sm">{t.about.stats.leakage}</p>
          </div>
          <div class="border-l-2 border-secondary pl-md">
            <p class="font-label-md text-label-md text-secondary">95%</p>
            <p class="font-label-sm text-label-sm">{t.about.stats.coverage}</p>
          </div>
          <div class="border-l-2 border-primary pl-md">
            <p class="font-label-md text-label-md text-primary">40%</p>
            <p class="font-label-sm text-label-sm">{t.about.stats.efficiency}</p>
          </div>
          <div class="border-l-2 border-secondary pl-md">
            <p class="font-label-md text-label-md text-secondary">100+</p>
            <p class="font-label-sm text-label-sm">{t.about.stats.endpoints}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
