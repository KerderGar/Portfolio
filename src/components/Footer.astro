---
import { getTranslation, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslation(locale);
---

<footer class="w-full bg-surface-container-lowest dark:bg-surface-container-lowest border-t border-outline-variant/20">
  <div class="flex flex-col md:flex-row justify-between items-center px-margin-desktop py-lg gap-md max-w-[1280px] mx-auto">
    <div class="font-label-md text-label-md text-on-surface">
      {t.footer.name}
    </div>
    <div class="font-label-sm text-label-sm text-secondary dark:text-secondary text-center md:text-left">
      © <span id="year">2024</span> {t.footer.copyright}
    </div>
  </div>
</footer>

<script>
  document.getElementById('year').textContent = new Date().getFullYear().toString();
</script>
