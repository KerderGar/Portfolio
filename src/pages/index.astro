---
const base = process.env.VERCEL ? '' : '/Portfolio';
const esUrl = base + '/es/';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting...</title>
  </head>
  <body>
    <script>
      (function() {
        const navLang = navigator.language || navigator.userLanguage || 'es';
        const lang = navLang.toLowerCase().startsWith('en') ? 'en' : 'es';
        const baseUrl = import.meta.env.BASE_URL;
        window.location.replace(baseUrl.endsWith('/') ? baseUrl + lang + '/' : baseUrl + '/' + lang + '/');
      })();
    </script>
    <noscript>
      <meta http-equiv="refresh" content={"0; url=" + esUrl} />
    </noscript>
  </body>
</html>
